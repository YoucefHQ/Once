{
  "name": "Once",
  "options_page": "options.html",
  "background": {
    "scripts": ["background.bundle.js"]
  },
  "browser_action": {
    "default_icon": "icon-34.png"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "permissions": ["tabs", "storage"],
  "web_accessible_resources": ["icon-128.png", "icon-34.png"],
  "manifest_version": 2,
  "content_security_policy": "script-src 'self' 'unsafe-eval' https://www.gstatic.com/ https://*.firebaseio.com https://apis.google.com; object-src 'self' 'unsafe-eval'"
}
