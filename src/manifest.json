{
  "version": "0.2.1",
  "name": "Once - Block distracting websites",
  "description": "Block distracting websites and limit visits to once per hour.",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.bundle.js",
    "type": "module"
  },
  "minimum_chrome_version": "102",
  "action": {
    "default_title": "Once - Block distracting websites",
    "default_icon": {
      "16": "icon-16.png",
      "24": "icon-24.png",
      "32": "icon-32.png",
      "128": "icon-128.png",
      "240": "icon-240.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "24": "icon-24.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png",
    "240": "icon-240.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.fandom.com/",
        "https://www.walmart.com/",
        "https://www.ebay.com/",
        "https://www.nytimes.com/",
        "https://www.amazon.com/",
        "https://www.bbc.com/",
        "https://www.buzzfeed.com/",
        "https://www.cnbc.com/",
        "https://www.cnn.com/",
        "https://www.espn.com/",
        "https://www.facebook.com/",
        "https://www.foxnews.com/",
        "https://news.ycombinator.com/",
        "https://www.instagram.com/",
        "https://www.linkedin.com/",
        "https://www.linkedin.com/feed/",
        "https://www.msn.com/",
        "https://www.pinterest.com/",
        "https://www.quora.com/",
        "https://www.reddit.com/",
        "https://techmeme.com/",
        "https://x.com/",
        "https://x.com/home",
        "https://www.tiktok.com/",
        "https://www.yahoo.com/",
        "https://www.youtube.com/"
      ],
      "js": ["contentScript.bundle.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["tabs", "storage", "activeTab"],
  "host_permissions": ["https://news.ycombinator.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["icon-240.png"],
      "matches": [
        "https://*.fandom.com/*",
        "https://*.walmart.com/*",
        "https://*.ebay.com/*",
        "https://*.nytimes.com/*",
        "https://*.amazon.com/*",
        "https://*.bbc.com/*",
        "https://*.buzzfeed.com/*",
        "https://*.cnbc.com/*",
        "https://*.cnn.com/*",
        "https://*.espn.com/*",
        "https://*.facebook.com/*",
        "https://*.foxnews.com/*",
        "https://news.ycombinator.com/*",
        "https://*.instagram.com/*",
        "https://*.linkedin.com/*",
        "https://*.msn.com/*",
        "https://*.pinterest.com/*",
        "https://*.quora.com/*",
        "https://*.reddit.com/*",
        "https://techmeme.com/*",
        "https://x.com/*",
        "https://*.tiktok.com/*",
        "https://*.yahoo.com/*",
        "https://*.youtube.com/*"
      ]
    }
  ],
  "manifest_version": 3
}
