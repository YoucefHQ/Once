{
  "name": "Once - Block distracting websites",
  "description": "Become more productive and stop wasting time on distracting websites.",
  "options_page": "options.html",
  "background": {
    "service_worker": "background.bundle.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "24": "icon-24.png",
      "32": "icon-32.png",
      "128": "icon-128.png",
      "240": "icon-240.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "24": "icon-24.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png",
    "240": "icon-240.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.fandom.com/",
        "https://www.walmart.com/",
        "https://www.ebay.com/",
        "https://www.nytimes.com/",
        "https://www.amazon.com/",
        "https://www.bbc.com/",
        "https://www.buzzfeed.com/",
        "https://www.cnbc.com/",
        "https://www.cnn.com/",
        "https://www.espn.com/",
        "https://www.facebook.com/",
        "https://www.foxnews.com/",
        "https://news.ycombinator.com/",
        "https://www.instagram.com/",
        "https://www.linkedin.com/",
        "https://www.linkedin.com/feed/",
        "https://www.msn.com/",
        "https://www.pinterest.com/",
        "https://www.quora.com/",
        "https://www.reddit.com/",
        "https://techmeme.com/",
        "https://x.com/",
        "https://x.com/home",
        "https://www.tiktok.com/",
        "https://www.yahoo.com/",
        "https://www.youtube.com/"
      ],
      "js": ["contentScript.bundle.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["tabs", "storage"],
  "web_accessible_resources": [
    {
      "resources": [
        "icon-16.png",
        "icon-24.png",
        "icon-32.png",
        "icon-48.png",
        "icon-128.png",
        "icon-240.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "manifest_version": 3
}
